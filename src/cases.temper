  cs.add(new ConformanceCase("dynamic_configuration.capability_http_header_tags", new Map<String, String>([new Pair("DD_REMOTE_CONFIGURATION_ENABLED", "true"), new Pair("DD_REMOTE_CONFIG_POLL_INTERVAL_SECONDS", "0.5"), new Pair("DD_SERVICE", "test_service"), new Pair("DD_ENV", "test_env")]), runRcCapabilityHttpHeaderTags, false, new ListBuilder<String>().toList(), true));
  cs.add(new ConformanceCase("dynamic_configuration.capability_custom_tags", new Map<String, String>([new Pair("DD_REMOTE_CONFIGURATION_ENABLED", "true"), new Pair("DD_REMOTE_CONFIG_POLL_INTERVAL_SECONDS", "0.5"), new Pair("DD_SERVICE", "test_service"), new Pair("DD_ENV", "test_env")]), runRcCapabilityCustomTags, false, new ListBuilder<String>().toList(), true));
  cs.add(new ConformanceCase("dynamic_configuration.capability_sample_rules", new Map<String, String>([new Pair("DD_REMOTE_CONFIGURATION_ENABLED", "true"), new Pair("DD_REMOTE_CONFIG_POLL_INTERVAL_SECONDS", "0.5"), new Pair("DD_SERVICE", "test_service"), new Pair("DD_ENV", "test_env")]), runRcCapabilitySampleRules, false, new ListBuilder<String>().toList(), true));
