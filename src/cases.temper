// # Conformance case registry

// The single source of truth for "what to run". Each case pairs a name, the env
// the tracer must be built with, and the `run` function. The in-repo validation
// and every native adapter iterate this list: build a tracer configured with
// `case.env`, then call `case.run(tracer)`.

// `fakeSupported` is false for behavior-heavy cases (e.g. sampling-rule
// evaluation) that the in-repo `FakeTracer` cannot faithfully model without
// reimplementing a tracer; those run only against real `dd-trace-*` adapters.

// `unsupported` lists library ids (e.g. `"nodejs"`) that don't implement the
// behavior; adapters skip those cases (mirrors upstream `@missing_feature`).

export class ConformanceCase(
  public name: String,
  public env: Mapped<String, String>,
  public run: fn (Tracer): CheckResult,
  public fakeSupported: Boolean = true,
  public unsupported: Listed<String> = new ListBuilder<String>().toList(),
  // when true, the runner points the tracer at a real ddapm-test-agent and the
  // case asserts on what was delivered over the wire (deliveredSpans/computedStatsJson)
  public needsAgent: Boolean = false,
) {}

let noEnv(): Mapped<String, String> { new Map<String, String>([]) }

let sssEnv(spanRules: String, traceRate: String, traceRules: String): Mapped<String, String> {
  new Map<String, String>([
    new Pair("DD_SPAN_SAMPLING_RULES", spanRules),
    new Pair("DD_TRACE_SAMPLE_RATE", traceRate),
    new Pair("DD_TRACE_SAMPLING_RULES", traceRules),
  ])
}

