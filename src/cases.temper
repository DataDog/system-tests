  cs.add(new ConformanceCase("library_tracestats.TS001", new Map<String, String>([new Pair("DD_TRACE_STATS_COMPUTATION_ENABLED", "1"), new Pair("DD_TRACE_API_VERSION", "v0.4"), new Pair("_DD_TRACE_STATS_WRITER_INTERVAL", "1")]), runStatsTS001, false, ["nodejs"], true));
  cs.add(new ConformanceCase("partial_flushing.one_span", new Map<String, String>([new Pair("DD_TRACE_PARTIAL_FLUSH_MIN_SPANS", "1"), new Pair("DD_TRACE_PARTIAL_FLUSH_ENABLED", "true")]), runPartialFlushOneSpan, false, new ListBuilder<String>().toList(), true));
  cs.add(new ConformanceCase("dynamic_configuration.capability_sample_rate", new Map<String, String>([new Pair("DD_REMOTE_CONFIGURATION_ENABLED", "true"), new Pair("DD_REMOTE_CONFIG_POLL_INTERVAL_SECONDS", "0.5"), new Pair("DD_SERVICE", "test_service"), new Pair("DD_ENV", "test_env")]), runRcCapabilitySampleRate, false, new ListBuilder<String>().toList(), true));
  cs.add(new ConformanceCase("dynamic_configuration.capability_enabled", new Map<String, String>([new Pair("DD_REMOTE_CONFIGURATION_ENABLED", "true"), new Pair("DD_REMOTE_CONFIG_POLL_INTERVAL_SECONDS", "0.5"), new Pair("DD_SERVICE", "test_service"), new Pair("DD_ENV", "test_env")]), runRcCapabilityEnabled, false, new ListBuilder<String>().toList(), true));
