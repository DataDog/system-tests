  cs.add(new ConformanceCase("headers_precedence.datadog", styleEnv("Datadog", "Datadog"), runPrecedenceDatadog, false));
  cs.add(new ConformanceCase("headers_precedence.tracecontext", styleEnv("tracecontext", "tracecontext"), runPrecedenceTracecontext, false));
  cs.add(new ConformanceCase("headers_precedence.tracecontext_datadog", styleEnv("tracecontext,Datadog", "tracecontext,Datadog"), runPrecedenceTcDd, false));
  cs.add(new ConformanceCase("headers_precedence.datadog_tracecontext", styleEnv("Datadog,tracecontext", "Datadog,tracecontext"), runPrecedenceDdTc, false));
  let styleEnvEf(style: String, extractFirst: String): Mapped<String, String> {
    new Map<String, String>([
      new Pair("DD_TRACE_PROPAGATION_STYLE_EXTRACT", style),
      new Pair("DD_TRACE_PROPAGATION_STYLE_INJECT", style),
      new Pair("DD_TRACE_PROPAGATION_EXTRACT_FIRST", extractFirst),
    ])
  };
  cs.add(new ConformanceCase("headers_precedence.tc_last_extract_first_true", styleEnvEf("Datadog,b3multi,tracecontext", "true"), runPrecTcLastExtractFirstTrue, false));
  cs.add(new ConformanceCase("headers_precedence.tc_first_extract_first_false", styleEnvEf("tracecontext,Datadog,b3multi", "false"), runPrecTcFirstExtractFirstFalse, false));
  cs.add(new ConformanceCase("headers_precedence.tc_first_extract_first_true", styleEnvEf("tracecontext,Datadog,b3multi", "true"), runPrecTcFirstExtractFirstTrue, false));

  let dd128Env(gen: String): Mapped<String, String> {
    new Map<String, String>([
      new Pair("DD_TRACE_PROPAGATION_STYLE", "Datadog"),
      new Pair("DD_TRACE_128_BIT_TRACEID_GENERATION_ENABLED", gen),
    ])
  };
  cs.add(new ConformanceCase("traceids_128bit.datadog_propagation", dd128Env("false"), runDd128Propagation, false));
  cs.add(new ConformanceCase("traceids_128bit.datadog_tid_long", dd128Env("false"), runDd128TidLong, false));
  cs.add(new ConformanceCase("traceids_128bit.datadog_tid_short", dd128Env("false"), runDd128TidShort, false));
  cs.add(new ConformanceCase("traceids_128bit.datadog_tid_chars", dd128Env("false"), runDd128TidChars, false));
  cs.add(new ConformanceCase("traceids_128bit.datadog_prop_and_gen", dd128Env("true"), runDd128PropAndGen, false));
  cs.add(new ConformanceCase("traceids_128bit.datadog_gen_disabled", dd128Env("false"), runDd128GenDisabled, false));
  cs.add(new ConformanceCase("traceids_128bit.datadog_gen_enabled", dd128Env("true"), runDd128GenEnabled, false));
