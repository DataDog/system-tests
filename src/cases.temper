  cs.add(new ConformanceCase("span_sampling.sss011_manual_drop_kept",
    sssEnv("[{\"service\": \"webserver\", \"name\": \"web.request\", \"sample_rate\": 1.0}]", "1.0", "[{\"sample_rate\":1.0}]"), runSssManualDropKept, false));
  cs.add(new ConformanceCase("span_sampling.sss012_tracer_keep_overrides",
    sssEnv("[{\"service\": \"webserver\", \"name\": \"web.request\", \"sample_rate\": 0}]", "1.0", "[{\"sample_rate\":1.0}]"), runSssTracerKeepNoSss, false));
  cs.add(new ConformanceCase("span_sampling.sss014_root_selected",
    sssEnv("[{\"service\": \"webserver\", \"name\": \"parent\", \"sample_rate\": 1.0, \"max_per_second\": 50}]", "0", dropTrace), runSssParentSelected, false));
  cs.add(new ConformanceCase("span_sampling.sss015_child_selected",
