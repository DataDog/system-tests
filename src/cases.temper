    new Map<String, String>([new Pair("DD_TRACE_PROPAGATION_STYLE", "Datadog")]), runDd128GenEnabled, false));

  let tcStyle = new Map<String, String>([new Pair("DD_TRACE_PROPAGATION_STYLE_EXTRACT", "tracecontext"), new Pair("DD_TRACE_PROPAGATION_STYLE_INJECT", "tracecontext")]);
