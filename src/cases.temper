  cs.add(new ConformanceCase("headers_tracestate_dd.evicts_32", tscDdEnv, runTracestateEvicts32, false, ["nodejs", "python"]));

  // ---- config_consistency (more) ----
  cs.add(new ConformanceCase("config_consistency.tracing_enabled_default", new Map<String, String>([]), runTracingEnabled, false));
  cs.add(new ConformanceCase("config_consistency.tracing_enabled_explicit", new Map<String, String>([new Pair("DD_TRACE_ENABLED", "true")]), runTracingEnabled, false));
  cs.add(new ConformanceCase("config_consistency.default_config", new Map<String, String>([]), runDefaultConfig, false));
  cs.add(new ConformanceCase("config_consistency.agent_http_url_ipv6", new Map<String, String>([new Pair("DD_TRACE_AGENT_URL", "http://[::1]:5000")]), runAgentHttpUrlIpv6, false));
  cs.add(new ConformanceCase("config_consistency.tags_comma_simple", new Map<String, String>([new Pair("DD_TAGS", "key1:value1,key2:value2")]), runTagsCommaSimple, false));
  cs.add(new ConformanceCase("config_consistency.tags_space", new Map<String, String>([new Pair("DD_TAGS", "key1:value1 key2:value2"), new Pair("DD_TRACE_EXPERIMENTAL_FEATURES_ENABLED", "all")]), runTagsCommaSimple, false));
  cs.add(new ConformanceCase("config_consistency.tracing_disabled", new Map<String, String>([new Pair("DD_TRACE_ENABLED", "false")]), runTracingDisabled, false));
  cs.add(new ConformanceCase("config_consistency.agent_host_ipv6", new Map<String, String>([new Pair("DD_AGENT_HOST", "::1"), new Pair("DD_TRACE_AGENT_PORT", "5000")]), runAgentHttpUrlIpv6, false));
  cs.add(new ConformanceCase("config_consistency.tags_colon_value", new Map<String, String>([new Pair("DD_TAGS", "a:b:c:d")]), runTagsColonValue, false));

  // ---- B3 single-key / case-insensitive style variants (reuse existing run fns) ----
  cs.add(new ConformanceCase("headers_b3.single_key_propagate_valid", new Map<String, String>([new Pair("DD_TRACE_PROPAGATION_STYLE", "B3 single header")]), runB3SinglePropagateValid, false));
  cs.add(new ConformanceCase("headers_b3multi.single_key_propagate_valid", new Map<String, String>([new Pair("DD_TRACE_PROPAGATION_STYLE", "b3multi")]), runB3multiPropagateValid, false));
  cs.add(new ConformanceCase("headers_b3multi.case_insensitive_extract", new Map<String, String>([new Pair("DD_TRACE_PROPAGATION_STYLE_EXTRACT", "B3MULTI"), new Pair("DD_TRACE_PROPAGATION_STYLE_INJECT", "b3multi")]), runB3multiPropagateValid, false));

  cs.toList()
}
