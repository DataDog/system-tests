// DD_TRACE_ENABLED=false: the tracer must not emit any spans to the agent.
export let runTracingDisabled(t: Tracer): CheckResult {
  let c = new Checker();
  let s = t.startSpan("allowed", "0");
  t.finishSpan(s.spanId);
  t.flush();
  c.eqInt(t.capturedSpans().length, 0, "no spans emitted when tracing disabled");
  c.result()
}
