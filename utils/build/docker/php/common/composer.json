{
    "name": "php/weblog",
    "type": "project",
    "require": {
        "weblog/acme": "*",
        "monolog/monolog": "*",
        "open-telemetry/sdk": "^1.0.0",
        "open-telemetry/exporter-otlp": "^1.0.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./Acme",
            "options": {
                "symlink": true
            }
        }
    ]
}
