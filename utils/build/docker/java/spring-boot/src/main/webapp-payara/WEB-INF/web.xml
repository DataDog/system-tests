<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0"
         metadata-complete="false">
    <!--
        Adds multipart-config to the Spring Boot DispatcherServlet so that Payara's
        Catalina-based Request.parseParts() does not abort early with no-multipart-config.
        Without this, request.getParts() sets an IllegalStateException and returns no parts,
        preventing AppSec from seeing uploaded file names.

        This file is only included in the Payara WAR build (via the payara Maven profile).
    -->
    <servlet>
        <servlet-name>dispatcherServlet</servlet-name>
        <multipart-config/>
    </servlet>
</web-app>
